generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  phone         String    @unique
  regNumber     String    @unique
  program       String
  yearOfStudy   Int
  password      String
  role          String    @default("MEMBER") // MEMBER | ADMIN
  paymentStatus String    @default("PENDING") // PENDING | PAID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  rsvps         EventRSVP[]
  blogPosts     BlogPost[]
}

model Event {
  id          String      @id @default(cuid())
  title       String
  date        String
  time        String
  venue       String
  category    String
  description String
  status      String      @default("Open")
  spots       Int
  createdAt   DateTime    @default(now())
  rsvps       EventRSVP[]
}

model EventRSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  content   String   @default("")
  category  String
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  authorName String  @default("")
  authorRole String  @default("")
  date      String
  readTime  String
  featured  Boolean  @default(false)
  image     String   @default("")
  createdAt DateTime @default(now())
}

model Award {
  id           String @id @default(cuid())
  title        String
  recipient    String
  organization String
  date         String
  category     String
  description  String
}

model GalleryImage {
  id          String @id @default(cuid())
  title       String
  category    String
  artist      String
  description String
  imageUrl    String @default("")
}

model Leader {
  id       String  @id @default(cuid())
  name     String
  role     String  @unique
  image    String  @default("")
  bio      String
  isPatron Boolean @default(false)
  badges   String  @default("[]") // JSON array stored as string
  sortOrder Int    @default(0)
}
